{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_CODE_NO_FLICKER": "1",
		"DISABLE_AUTOUPDATER": "0",
		"DISABLE_ERROR_REPORTING": "1"
	},
	"includeCoAuthoredBy": false,
	"permissions": {
		"allow": [],
		"deny": [
			"Bash(*brew install *)",
			"Bash(*chmod 777 *)",
			"Bash(*gh pr merge*)",
			"Bash(*gh merge*)",
			"Bash(*gh repo delete*)",
			"Bash(*git config *)",
			"Bash(*git add -f*)",
			"Bash(*rm -rf *)"
		],
		"defaultMode": "auto"
	},
	"model": "claude-fable-5[1m]",
	"hooks": {
		"Notification": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "uv run ~/.claude/hooks/notify.py"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "uv run ~/.claude/hooks/notify.py"
					}
				]
			}
		],
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun ~/.claude/hooks/watch-launch.ts"
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun ~/.claude/hooks/watch-stop.ts"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "bun D:/projects/cc-discord/plugin/src/statusline-tee.ts uv run ~/.claude/scripts/statusline.py --icons=nerd",
		"padding": 0
	},
	"enabledPlugins": {
		"chrome-devtools-mcp@claude-plugins-official": true,
		"clangd-lsp@claude-plugins-official": false,
		"claude-md-management@claude-plugins-official": true,
		"code-review@claude-plugins-official": true,
		"code-simplifier@claude-plugins-official": true,
		"coderabbit@claude-plugins-official": true,
		"codex@openai-codex": true,
		"csharp-lsp@claude-plugins-official": false,
		"discord@claude-plugins-official": true,
		"feature-dev@claude-plugins-official": true,
		"frontend-design@claude-plugins-official": true,
		"gopls-lsp@claude-plugins-official": false,
		"jdtls-lsp@claude-plugins-official": false,
		"kotlin-lsp@claude-plugins-official": false,
		"lua-lsp@claude-plugins-official": false,
		"php-lsp@claude-plugins-official": false,
		"playwright-cli@playwright-cli": true,
		"playwright@claude-plugins-official": true,
		"pr-review-toolkit@claude-plugins-official": true,
		"pyright-lsp@claude-plugins-official": false,
		"ralph-loop@claude-plugins-official": true,
		"ruby-lsp@claude-plugins-official": false,
		"rust-analyzer-lsp@claude-plugins-official": false,
		"security-guidance@claude-plugins-official": true,
		"skill-creator@claude-plugins-official": true,
		"superpowers@claude-plugins-official": true,
		"swift-lsp@claude-plugins-official": false,
		"typescript-lsp@claude-plugins-official": false
	},
	"extraKnownMarketplaces": {
		"openai-codex": {
			"source": {
				"source": "github",
				"repo": "openai/codex-plugin-cc"
			}
		},
		"svelte": {
			"source": {
				"source": "github",
				"repo": "sveltejs/ai-tools"
			}
		}
	},
	"language": "日本語",
	"effortLevel": "xhigh",
	"promptSuggestionEnabled": false,
	"autoUpdatesChannel": "latest",
	"skipDangerousModePermissionPrompt": true,
	"theme": "dark",
	"preferredNotifChannel": "notifications_disabled",
	"remoteControlAtStartup": true,
	"inputNeededNotifEnabled": true,
	"agentPushNotifEnabled": true,
	"feedbackSurveyState": {
		"lastShownTime": 1754086803253
	}
}
