[user]
	name = xin
	email = 98406118+9c5s@users.noreply.github.com
	signingkey = ~/.ssh/id_ed25519.pub
[core]
	editor = code --wait
	autocrlf = input
	symlinks = true
	excludesfile = ~/.gitignore
[credential "https://github.com"]
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = !gh auth git-credential
[commit]
	gpgsign = true
[gpg]
	format = ssh
[init]
	defaultbranch = main
[pull]
	rebase = true
[coderabbit]
	machineId = cli/9f56e88424404ceca69ee41fc2515ba8
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential]
	helper = 
	helper = C:/Users/shun/AppData/Local/Programs/Git\\ Credential\\ Manager/git-credential-manager.exe
